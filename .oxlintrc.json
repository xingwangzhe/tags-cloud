{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn",
    "style": "warn",
    "pedantic": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "rules": {
    "no-console": "warn",
    "no-debugger": "error",
    "no-alert": "warn",
    "no-eval": "error",
    "no-var": "error",
    "prefer-const": "error",
    "eqeqeq": ["error", "always"],
    "no-duplicate-imports": "error",
    "no-unused-vars": "warn",
    "arrow-body-style": "off",
    "import/no-default-export": "off",
    "import/no-named-export": "off",
    "import/group-exports": "off",
    "import/exports-last": "off",
    "typescript/no-non-null-assertion": "off",
    "typescript/consistent-type-imports": "warn",
    "typescript/consistent-type-definitions": ["warn", "interface"],
    "unicorn/filename-case": "off",
    "unicorn/prefer-node-protocol": "warn",
    "unicorn/prefer-global-this": "off",
    "no-magic-numbers": "off",
    "no-ternary": "off",
    "no-underscore-dangle": ["error", { "allow": ["_rotatePoint", "_rotatePoints"] }],
    "capitalized-comments": "off",
    "sort-keys": "off",
    "no-continue": "off",
    "no-implicit-coercion": "off",
    "no-null": "off",
    "max-params": "off",
    "max-statements": "off",
    "prefer-destructuring": "off",
    "consistent-generic-constructors": "off",
    "oxc/no-map-spread": "off",
    "id-length": "off"
  },
  "plugins": ["import", "typescript", "unicorn", "oxc"],
  "settings": {},
  "ignorePatterns": ["dist", "out", "node_modules", "vendor", "*.js", "*.mjs", "*.cjs"],
  "env": {
    "browser": true,
    "es2024": true
  },
  "globals": {}
}
