{
  "name": "@xingwangzhe/tags-cloud",
  "version": "0.5.0",
  "description": "Canvas-driven 3D tag cloud engine / Canvas 驱动的 3D 标签云引擎",
  "keywords": [
    "3d",
    "canvas",
    "sphere",
    "tag-cloud",
    "tags"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "vite": "^8.0.16"
  }
}
