{
  "name": "@xingwangzhe/tags-cloud",
  "version": "1.0.5",
  "description": "Canvas-driven 3D tag cloud engine",
  "keywords": [
    "3d",
    "canvas",
    "sphere",
    "tag-cloud",
    "tags"
  ],
  "license": "MIT",
  "author": "xingwangzhe",
  "repository": {
    "type": "git",
    "url": "https://github.com/xingwangzhe/tags-cloud"
  },
  "files": [
    "dist",
    "src/core",
    "src/index.ts",
    "src/TagCloud.ts"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build -c vite.demo.config.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "vite": "^8.0.16"
  }
}
